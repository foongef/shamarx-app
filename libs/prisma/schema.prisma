generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  passwordResetTokens PasswordResetToken[]

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model EquitySnapshot {
  id              String   @id @default(uuid())
  takenAt         DateTime @default(now())
  source          String   @default("live")  // "live" | "backtest"
  mode            String                     // "mock" | "metaapi"
  balance         Float
  equity          Float
  unrealizedPnl   Float    @default(0)
  margin          Float    @default(0)
  freeMargin      Float    @default(0)
  openPositions  Int      @default(0)

  @@index([source, takenAt])
}

model Candle {
  id        String   @id @default(uuid())
  symbol    String
  timeframe String
  openTime  DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())

  @@unique([symbol, timeframe, openTime])
  @@index([symbol, timeframe, openTime])
}

model ImportCheckpoint {
  id           String   @id @default(uuid())
  symbol       String
  timeframe    String
  source       String   @default("dukascopy")
  lastOpenTime DateTime
  rowsImported Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([symbol, timeframe, source])
}

model Indicator {
  id        String   @id @default(uuid())
  symbol    String
  timeframe String
  openTime  DateTime
  name      String
  value     Float
  createdAt DateTime @default(now())

  @@unique([symbol, timeframe, openTime, name])
  @@index([symbol, timeframe, name])
}

model SpreadSnapshot {
  id        String   @id @default(uuid())
  symbol    String
  bid       Float
  ask       Float
  spread    Float
  timestamp DateTime @default(now())

  @@index([symbol, timestamp])
}

model SupportResistanceLevel {
  id        String   @id @default(uuid())
  symbol    String
  timeframe String
  price     Float
  type      String   // SUPPORT or RESISTANCE
  strength  Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([symbol, timeframe, isActive])
}

model CandidateTrade {
  id          String   @id @default(uuid())
  symbol      String
  side        String   // BUY or SELL
  entryPrice  Float
  slPrice     Float
  tpPrice     Float
  slPoints    Float
  tpPoints    Float
  setupTags   String[] // e.g. ["BOS", "PULLBACK_EMA20", "ENGULFING"]
  h1Bias      String   // BULLISH, BEARISH, NEUTRAL
  rsiValue    Float
  atrValue    Float
  spreadAtDetection Float
  timeframe   String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())

  llmDecision LlmDecision?
  trade       Trade?

  @@index([status, createdAt])
}

model LlmDecision {
  id            String   @id @default(uuid())
  candidateId   String   @unique
  candidate     CandidateTrade @relation(fields: [candidateId], references: [id])
  decision      String   // ALLOW or REJECT
  confidence    Float
  reasoning     String
  toolsUsed     String[]
  rawResponse   String
  inputTokens   Int
  outputTokens  Int
  latencyMs     Int
  createdAt     DateTime @default(now())
}

model Trade {
  id             String   @id @default(uuid())
  candidateId    String   @unique
  candidate      CandidateTrade @relation(fields: [candidateId], references: [id])
  clientOrderId  String?  @unique
  mt5Ticket      Int?
  sessionId      String?
  session        LiveSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  symbol         String
  side           String
  lotSize        Float
  entryPrice     Float
  closePrice     Float?
  slPrice        Float
  tpPrice        Float
  status         String   @default("PENDING") // PENDING, OPEN, CLOSED, CANCELLED
  exitReason     String?  // SL, TP, BREAKEVEN, FORCED_CLOSE
  pnl            Float?
  closedAt       DateTime?
  statusHistory  Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  journalEntry   JournalEntry?

  @@index([status])
  @@index([symbol, createdAt])
  @@index([sessionId])
}

model LiveSession {
  id               String    @id @default(uuid())
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  strategyVersion  String
  riskPercent      Float
  mode             String    // "mock" | "metaapi"
  mockBalance      Float?
  startEquity      Float
  endEquity        Float?
  realizedPnl      Float     @default(0)
  tradesCount      Int       @default(0)
  winsCount        Int       @default(0)
  lossesCount      Int       @default(0)
  status           String    @default("RUNNING") // RUNNING, ENDED, CRASHED
  pairs            String[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trades           Trade[]

  @@index([status, startedAt])
}

model RiskState {
  id                  String   @id @default(uuid())
  date                DateTime @unique @db.Date
  dailyPnl            Float    @default(0)
  consecutiveLosses   Int      @default(0)
  openPositionCount   Int      @default(0)
  dailyLossLimitHit   Boolean  @default(false)
  consecutiveLossLimitHit Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RiskConfig {
  id                    String @id @default(uuid())
  maxDailyLossPercent   Float  @default(3.0)
  maxOpenPositions      Int    @default(3)
  maxConsecutiveLosses  Int    @default(3)
  riskPerTradePercent   Float  @default(1.0)
  maxSpreadPoints       Float  @default(50)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model JournalEntry {
  id            String   @id @default(uuid())
  tradeId       String   @unique
  trade         Trade    @relation(fields: [tradeId], references: [id])
  setupSummary  String
  llmReasoning  String
  entryContext  Json?
  exitContext   Json?
  outcome       String?
  tags          String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EconomicEvent {
  id        String   @id @default(uuid())
  title     String
  country   String
  impact    String   // HIGH, MEDIUM, LOW
  eventTime DateTime
  actual    String?
  forecast  String?
  previous  String?
  createdAt DateTime @default(now())

  @@index([eventTime, impact])
  @@unique([title, eventTime])
}

model BacktestRun {
  id             String    @id @default(uuid())
  symbol         String    @default("XAUUSD")
  startDate      DateTime
  endDate        DateTime
  initialBalance Float
  riskPercent    Float
  withLlm        Boolean   @default(false)
  strategyVersion String?  // V5.5b | V6 | V6-alt — null for legacy runs
  status         String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  metrics        Json?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  trades         BacktestTrade[]

  @@index([status, createdAt])
}

model BacktestTrade {
  id            String   @id @default(uuid())
  backtestRunId String
  backtestRun   BacktestRun @relation(fields: [backtestRunId], references: [id], onDelete: Cascade)
  side          String
  entryPrice    Float
  exitPrice     Float
  slPrice       Float
  tpPrice       Float
  lotSize       Float
  pnl           Float
  commission    Float    @default(0)
  setupTags     String[]
  entryTime     DateTime
  exitTime      DateTime
  exitReason    String   // SL, TP, FORCED_CLOSE
  h1Bias        String
  rsiAtEntry    Float
  atrAtEntry    Float

  @@index([backtestRunId])
}
