# Database
DATABASE_URL="postgresql://trading:trading@localhost:5432/trading_bot?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service Port
PORT=3000
EXECUTION_PORT=8000

# MiniMax LLM
MINIMAX_API_KEY=your_minimax_api_key_here
LLM_MODEL=MiniMax-M2.5

# Execution Service
EXECUTION_SERVICE_URL=http://localhost:8000
# MT5_MODE: mock (fake data), metaapi (real Pepperstone via MetaAPI)
MT5_MODE=mock

# Risk Defaults
MAX_DAILY_LOSS_PERCENT=3.0
MAX_OPEN_POSITIONS=3
MAX_CONSECUTIVE_LOSSES=3
RISK_PER_TRADE_PERCENT=1.0
MAX_SPREAD_POINTS=50

# MetaAPI Credentials (metaapi.cloud)
METAAPI_ACCOUNT_ID_DEMO=your_metaapi_account_id_here
METAAPI_ACCESS_TOKEN=your_metaapi_access_token_here

# ─── Multi-Account Broker Support (Spec 1) ───────────────────────────────────
# CryptoService uses dual-mode key sourcing:
#   - PRODUCTION: set BROKER_CREDS_SECRET_ID to the AWS Secrets Manager
#     secret name/ARN. App fetches once at boot via IAM role.
#   - LOCAL DEV: set BROKER_CREDS_KEY directly (32-byte hex). Faster, no
#     AWS dependency. Generate via: openssl rand -hex 32
# If both are set, BROKER_CREDS_SECRET_ID wins.
BROKER_CREDS_SECRET_ID=
BROKER_CREDS_KEY=

# Feature flag: when true, strategy engine fans out to ALL enabled
# BrokerAccount rows. When false, legacy single-account behavior runs
# (env-driven METAAPI creds path unchanged).
ENABLE_MULTI_ACCOUNT_FANOUT=false

# Soft cap on concurrently enabled accounts (per user). Default 5.
MULTI_ACCOUNT_SOFT_CAP=5

# ─── cTrader OAuth (Spec 3) ──────────────────────────────────────────────────
# Spotware OAuth app credentials. Register at https://openapi.ctrader.com/apps
# In prod, sourced from AWS Secrets Manager (shamarx/ctrader-oauth).
# Locally, paste them directly into .env.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=

# Where Spotware redirects after consent. Must match the Spotware app
# registration EXACTLY (scheme + host + path).
#   prod: https://app.shamarx.com/oauth/ctrader/callback
#   dev:  http://localhost:3000/oauth/ctrader/callback
CTRADER_REDIRECT_URI=http://localhost:3000/oauth/ctrader/callback

# Optional overrides — defaults are Spotware's published endpoints.
CTRADER_AUTH_BASE_URL=https://connect.spotware.com
CTRADER_TOKEN_URL=https://openapi.ctrader.com/apps/token
CTRADER_ACCOUNTS_URL=https://api.spotware.com/connect/tradingaccounts

# Internal backend URL used by execution-service to PATCH refreshed cTrader
# OAuth tokens back to NestJS for re-encryption. Docker-compose default is
# the backend service name; for tests or non-docker runs, point at localhost.
BACKEND_INTERNAL_URL=http://backend:3001
