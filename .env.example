# Database
DATABASE_URL="postgresql://trading:trading@localhost:5432/trading_bot?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service Port
PORT=3000
EXECUTION_PORT=8000

# MiniMax LLM
MINIMAX_API_KEY=your_minimax_api_key_here
LLM_MODEL=MiniMax-M2.5

# Execution Service
EXECUTION_SERVICE_URL=http://localhost:8000
# MT5_MODE: mock (fake data), metaapi (real Pepperstone via MetaAPI)
MT5_MODE=mock

# Risk Defaults
MAX_DAILY_LOSS_PERCENT=3.0
MAX_OPEN_POSITIONS=3
MAX_CONSECUTIVE_LOSSES=3
RISK_PER_TRADE_PERCENT=1.0
MAX_SPREAD_POINTS=50

# MetaAPI Credentials (metaapi.cloud)
METAAPI_ACCOUNT_ID_DEMO=your_metaapi_account_id_here
METAAPI_ACCESS_TOKEN=your_metaapi_access_token_here

# ─── Multi-Account Broker Support (Spec 1) ───────────────────────────────────
# 32-byte hex string used to encrypt BrokerAccount creds at rest.
# Generate via: openssl rand -hex 32
BROKER_CREDS_KEY=

# Feature flag: when true, strategy engine fans out to ALL enabled
# BrokerAccount rows. When false, legacy single-account behavior runs
# (env-driven METAAPI creds path unchanged).
ENABLE_MULTI_ACCOUNT_FANOUT=false

# Soft cap on concurrently enabled accounts (per user). Default 5.
MULTI_ACCOUNT_SOFT_CAP=5
