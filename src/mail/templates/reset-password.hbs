<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="color-scheme" content="dark">
  <title>Reset your Shamarx password</title>
</head>
<body style="margin:0; padding:0; background:#1a1612; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; color:#ece8e3;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#1a1612;">
    <tr>
      <td align="center" style="padding:48px 16px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="560" style="max-width:560px; background:#231f1a; border:1px solid #383229; border-radius:4px; overflow:hidden;">

          <!-- Top accent rail (Shamarx gold) -->
          <tr>
            <td style="height:1px; background:linear-gradient(90deg, transparent 0%, #F2C31C 50%, transparent 100%);" height="1"></td>
          </tr>

          <!-- Header -->
          <tr>
            <td style="padding:36px 40px 16px;">
              <div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:13px; font-weight:600; letter-spacing:0.16em; color:#F2C31C; text-transform:uppercase;">
                ▲ SHAMARX
              </div>
              <div style="margin-top:6px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:10px; letter-spacing:0.22em; color:#8d8275; text-transform:uppercase;">
                Password reset · 1 hour expiry
              </div>
            </td>
          </tr>

          <!-- Headline -->
          <tr>
            <td style="padding:12px 40px 8px;">
              <div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:28px; font-weight:500; line-height:1.15; letter-spacing:0.02em; color:#ece8e3;">
                Reset your <span style="color:#F2C31C;">password</span>.
              </div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:16px 40px 8px;">
              <p style="margin:0 0 16px; font-size:15px; line-height:1.6; color:#d4cfc8;">
                We received a request to reset the password for the account associated with <strong style="color:#ece8e3;">{{email}}</strong>.
              </p>
              <p style="margin:0 0 8px; font-size:15px; line-height:1.6; color:#d4cfc8;">
                Click below to set a new password. This link expires in <strong style="color:#ece8e3;">1 hour</strong> and can only be used once.
              </p>
            </td>
          </tr>

          <!-- CTA -->
          <tr>
            <td align="center" style="padding:24px 40px 8px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td align="center" style="background:#F2C31C; border-radius:4px;">
                    <a href="{{resetUrl}}" style="display:inline-block; padding:13px 30px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:11px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:#1a1612; text-decoration:none;">
                      Reset password
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Fallback link -->
          <tr>
            <td style="padding:24px 40px 0;">
              <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#8d8275;">
                Or paste this link
              </div>
              <p style="margin:8px 0 0; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:11px; line-height:1.5; color:#a39888; word-break:break-all;">
                <a href="{{resetUrl}}" style="color:#F2C31C; text-decoration:none;">{{resetUrl}}</a>
              </p>
            </td>
          </tr>

          <!-- Security note -->
          <tr>
            <td style="padding:20px 40px 32px;">
              <hr style="border:none; border-top:1px solid #383229; margin:12px 0 16px;">
              <p style="margin:0; font-size:11.5px; line-height:1.6; color:#8d8275;">
                If you didn't request a password reset, you can safely ignore this email — your password won't change. The link expires automatically in 1 hour.
              </p>
            </td>
          </tr>

          <!-- Bottom accent rail -->
          <tr>
            <td style="height:1px; background:linear-gradient(90deg, transparent 0%, #F2C31C 50%, transparent 100%); opacity:0.5;" height="1"></td>
          </tr>
        </table>

        <!-- Footer -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="560" style="max-width:560px; margin-top:16px;">
          <tr>
            <td align="center" style="padding:8px 40px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:10px; letter-spacing:0.22em; text-transform:uppercase; color:#5e5447;">
              SHAMARX · Guarded by design
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
