<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="color-scheme" content="dark">
  <title>{{symbol}} {{sideLabel}} opened</title>
</head>
<body style="margin:0; padding:0; background:#0a0a0a; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; color:#e5e5e5;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#0a0a0a;">
    <tr>
      <td align="center" style="padding:48px 16px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="560" style="max-width:560px; background:#141414; border:1px solid #262626; border-radius:6px; overflow:hidden;">

          <!-- Top accent rail (signal gold) -->
          <tr>
            <td style="height:1px; background:linear-gradient(90deg, transparent 0%, #ddb13d 50%, transparent 100%);" height="1"></td>
          </tr>

          <!-- Header -->
          <tr>
            <td style="padding:36px 40px 12px;">
              <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:10px; text-transform:uppercase; letter-spacing:0.22em; color:#ddb13d; margin-bottom:10px;">
                ShamarX · trade opened
              </div>
              <div style="font-family:ui-serif,Georgia,serif; font-size:30px; line-height:1.1; letter-spacing:0.01em; color:#fafafa;">
                {{symbol}} <span style="color:{{accentColor}};">{{sideLabel}}</span>
              </div>
              <div style="margin-top:8px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:11px; letter-spacing:0.16em; color:#737373; text-transform:uppercase;">
                {{mode}} · {{lotSize}} lot · {{riskLabel}} risk
              </div>
            </td>
          </tr>

          <!-- Direction strip -->
          <tr>
            <td style="padding:0 40px;">
              <div style="height:1px; background:#262626; margin:20px 0;"></div>
            </td>
          </tr>

          <!-- Trade detail grid -->
          <tr>
            <td style="padding:0 40px 8px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td width="50%" style="padding:0 12px 16px 0; vertical-align:top;">
                    <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#737373;">Entry</div>
                    <div style="margin-top:4px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:18px; color:#fafafa;">{{entryPrice}}</div>
                  </td>
                  <td width="50%" style="padding:0 0 16px 12px; vertical-align:top;">
                    <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#737373;">Opened</div>
                    <div style="margin-top:4px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:14px; color:#fafafa;">{{openedAtPretty}}</div>
                  </td>
                </tr>
                <tr>
                  <td width="50%" style="padding:0 12px 16px 0; vertical-align:top;">
                    <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#737373;">Stop loss</div>
                    <div style="margin-top:4px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:16px; color:#ef4444;">{{slPrice}}</div>
                  </td>
                  <td width="50%" style="padding:0 0 16px 12px; vertical-align:top;">
                    <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#737373;">Take profit</div>
                    <div style="margin-top:4px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:16px; color:#22c55e;">{{tpDisplay}}</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Reason -->
          <tr>
            <td style="padding:8px 40px 0;">
              <div style="font-family:'SF Mono',Menlo,Consolas,monospace; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#737373;">Setup</div>
              <p style="margin:6px 0 0; font-size:13.5px; line-height:1.6; color:#d4d4d4;">{{reason}}</p>
            </td>
          </tr>

          <!-- CTA -->
          <tr>
            <td align="center" style="padding:32px 40px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                <tr>
                  <td align="center" style="background:#ddb13d; border-radius:4px;">
                    <a href="{{dashboardUrl}}" style="display:inline-block; padding:12px 28px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:11px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:#0a0a0a; text-decoration:none;">View on dashboard</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Disclaimer -->
          <tr>
            <td style="padding:0 40px 32px; border-top:1px solid #262626;">
              <p style="margin:24px 0 0; font-size:11px; line-height:1.6; color:#525252;">
                This trade was placed automatically by the stop-hunt reversal engine. Position management (BE move, trail, TP partials) runs without further action from you. To stop the engine, use the dashboard "Stop session" button.
              </p>
            </td>
          </tr>

          <!-- Bottom accent rail -->
          <tr>
            <td style="height:1px; background:linear-gradient(90deg, transparent 0%, #ddb13d 50%, transparent 100%); opacity:0.6;" height="1"></td>
          </tr>
        </table>

        <!-- Footer outside card -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="560" style="max-width:560px; margin-top:16px;">
          <tr>
            <td align="center" style="padding:8px 40px; font-family:'SF Mono',Menlo,Consolas,monospace; font-size:10px; letter-spacing:0.22em; text-transform:uppercase; color:#525252;">
              ShamarX · Guarded by design
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
