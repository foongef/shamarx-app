{
  "name": "trading-bot",
  "version": "0.1.0",
  "description": "Bot Trading System",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "nest build",
    "build:backend": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "format": "prettier --write \"src/**/*.ts\" \"libs/**/*.ts\"",
    "docker:up": "docker compose --env-file .env -f docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.yml down",
    "docker:restart": "docker compose --env-file .env -f docker/docker-compose.yml up --build -d --force-recreate --no-deps",
    "docker:logs": "docker compose --env-file .env -f docker/docker-compose.yml logs -f",
    "docker:ps": "docker compose --env-file .env -f docker/docker-compose.yml ps",
    "prisma:generate": "prisma generate --schema=libs/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=libs/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=libs/prisma/schema.prisma",
    "seed:superadmin": "ts-node -P tsconfig.build.json --transpile-only scripts/seed-superadmin.ts",
    "data:import": "bash scripts/data-import.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.config.ts",
    "build:web": "pnpm --filter @app/web build",
    "web:dev": "pnpm --filter @app/web dev",
    "web:start": "pnpm --filter @app/web start",
    "host:stats": "bash scripts/host-stats.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-secrets-manager": "^3.1063.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.2.1",
    "argon2": "^0.44.0",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "handlebars": "^4.7.9",
    "ioredis": "^5.4.2",
    "nestjs-pino": "^4.6.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.21.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "technicalindicators": "^3.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^@app/prisma$": "<rootDir>/libs/prisma/src",
      "^@app/prisma/(.*)$": "<rootDir>/libs/prisma/src/$1",
      "^@app/common$": "<rootDir>/libs/common/src",
      "^@app/common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/redis$": "<rootDir>/libs/redis/src",
      "^@app/redis/(.*)$": "<rootDir>/libs/redis/src/$1"
    },
    "testEnvironment": "node"
  }
}